# Copie este arquivo para .env e preencha com valores reais. .env nunca é
# comitado (veja .gitignore) — nem localmente, nem no Vercel.

# Connection string do banco Postgres (ex.: Neon).
DATABASE_URL="postgresql://usuario:senha@host/banco?sslmode=require"

# Gere com: openssl rand -base64 32
AUTH_SECRET=""

# Códigos de acesso iniciais usados por `npx tsx prisma/seed.ts`. Escolha
# valores próprios — troque-os pela tela "Usuários" após o primeiro login.
SEED_CODIGO_ADMIN=""
SEED_CODIGO_CCMI=""
SEED_CODIGO_PROJETO=""
SEED_CODIGO_DIGITAL=""
SEED_CODIGO_OFICINACAO=""
